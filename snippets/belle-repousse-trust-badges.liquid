{% comment %}
  Shared purchase reassurance badges.
{% endcomment %}
<ul class="br-trust-badges" aria-label="{{ label | escape }}">
  <li class="br-trust-badges__item">
    <div class="br-trust-badges__link">
      <img class="br-trust-badges__image" src="{{ 'belle-repousse-badge-meilleur-prix.png' | asset_url }}" alt="Meilleur prix garanti" width="2139" height="415" loading="lazy">
    </div>
  </li>
  <li class="br-trust-badges__item">
    <div class="br-trust-badges__link">
      <img class="br-trust-badges__image" src="{{ 'belle-repousse-badge-retours-30-jours.png' | asset_url }}" alt="Retours sous 30 jours" width="2141" height="411" loading="lazy">
    </div>
  </li>
  <li class="br-trust-badges__item">
    <div class="br-trust-badges__link">
      <img class="br-trust-badges__image" src="https://trustlock.co/wp-content/uploads/2019/01/credit-card-logos-free-png-image-trans.png" alt="Paiement sécurisé" width="294" height="60" loading="lazy">
    </div>
  </li>
</ul>
