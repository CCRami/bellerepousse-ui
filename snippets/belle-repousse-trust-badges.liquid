{% comment %}
  Shared purchase reassurance badges.
{% endcomment %}
<ul class="br-trust-badges" aria-label="{{ label | escape }}">
  <li class="br-trust-badges__item">
    <a class="br-trust-badges__link" href="https://trustlock.co" target="_blank" rel="noopener noreferrer">
      <img class="br-trust-badges__image" src="https://trustlock.co/wp-content/uploads/2019/01/BEST-PRICE-GUARANTEED-badge.png" alt="" width="238" height="44" loading="lazy">
      <span>{{ best_price_label | escape }}</span>
    </a>
  </li>
  <li class="br-trust-badges__item">
    <a class="br-trust-badges__link" href="https://trustlock.co" target="_blank" rel="noopener noreferrer">
      <img class="br-trust-badges__image" src="https://trustlock.co/wp-content/uploads/2019/01/30-day-money-back-guarantee-badge-5.png" alt="" width="238" height="44" loading="lazy">
      <span>{{ returns_label | escape }}</span>
    </a>
  </li>
  <li class="br-trust-badges__item">
    <a class="br-trust-badges__link" href="https://trustlock.co" target="_blank" rel="noopener noreferrer">
      <img class="br-trust-badges__image" src="https://trustlock.co/wp-content/uploads/2019/01/credit-card-logos-free-png-image-trans.png" alt="" width="294" height="60" loading="lazy">
      <span>{{ payment_label | escape }}</span>
    </a>
  </li>
</ul>
