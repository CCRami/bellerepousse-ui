{% doc %}
Renders the Belle Repousse site header and footer for storefront templates.
{% enddoc %}

{{ 'belle-repousse-chrome.css' | asset_url | stylesheet_tag }}

<div class="br-site-chrome">
  <header class="br-site-header">
    <div class="br-site-header__inner">
      <a class="br-site-header__brand" href="{{ routes.root_url }}" aria-label="Belle Repousse - Accueil">Belle Repousse</a>
      <nav class="br-site-header__nav" aria-label="Navigation principale">
        <a href="{{ routes.root_url }}#produit">Le produit</a>
        <a href="{{ routes.root_url }}#bienfaits">Bienfaits</a>
        <a href="{{ routes.root_url }}#utilisation">Utilisation</a>
        <a href="{{ pages['faq'].url | default: routes.root_url | append: '#faq' }}">FAQ</a>
        <a href="{{ pages['contact'].url | default: '/pages/contact' }}">Contact</a>
      </nav>
      <a class="br-site-header__cart" href="{{ routes.cart_url }}" aria-label="Panier, {{ cart.item_count }} article(s)">Panier <span>{{ cart.item_count }}</span></a>
    </div>
  </header>

  <footer class="br-site-footer">
    <div class="br-site-footer__inner">
      <div class="br-site-footer__newsletter">
        <p class="br-site-footer__brand">Belle Repousse</p>
        <h2>Une routine qui commence par les racines</h2>
        <p>Recevez des conseils pour votre routine cuir chevelu et des nouvelles de Belle Repousse.</p>
        {% form 'customer', class: 'br-site-footer__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="BrChromeEmail">Votre e-mail</label>
          <input id="BrChromeEmail" type="email" name="contact[email]" placeholder="Votre e-mail" autocomplete="email" required>
          <button type="submit" aria-label="S'inscrire à la newsletter">→</button>
        {% endform %}
      </div>
      <nav class="br-site-footer__links" aria-label="Liens utiles">
        <a href="{{ pages['a-propos'].url | default: '/pages/a-propos' }}">À propos</a>
        <a href="{{ pages['faq'].url | default: '/pages/faq' }}">FAQ</a>
        <a href="/pages/politique-de-livraison">Livraison</a>
        <a href="/pages/conditions-generales-dutilisation">Conditions générales</a>
        <a href="/pages/politique-de-confidentialite">Confidentialité</a>
        <a href="/pages/politique-de-remboursements">Remboursements</a>
        <a href="{{ pages['contact'].url | default: '/pages/contact' }}">Contact</a>
      </nav>
      <div class="br-site-footer__bottom">
        <span>Accessoire de bien-être et de soin capillaire.</span>
        <span>© {{ 'now' | date: '%Y' }} Belle Repousse</span>
      </div>
    </div>
  </footer>
</div>
