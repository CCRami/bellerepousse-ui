{% doc %}
Renders the Belle Repousse site header for storefront templates.
{% enddoc %}

{{ 'belle-repousse-chrome.css' | asset_url | stylesheet_tag }}
{{ 'belle-repousse-enhancements.css' | asset_url | stylesheet_tag }}
{{ 'belle-repousse-header-overlay.css' | asset_url | stylesheet_tag }}

<div class="br-site-chrome">
  <header class="br-site-header">
    <div class="br-site-header__inner">
      <a class="br-site-header__brand" href="{{ routes.root_url }}" aria-label="Belle Repousse - Accueil">
        <img src="{{ 'belle-repousse-logo-transparent.png' | asset_url }}" alt="Belle Repousse" width="1756" height="724">
      </a>
      <a class="br-site-header__cart" href="{{ routes.cart_url }}" aria-label="Panier, {{ cart.item_count }} article(s)">Panier <span>{{ cart.item_count }}</span></a>
    </div>
  </header>
</div>
