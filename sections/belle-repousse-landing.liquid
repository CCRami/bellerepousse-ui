{% liquid
  assign featured_product = section.settings.featured_product
  assign selected_variant = featured_product.selected_or_first_available_variant
  assign product_available = false

  if featured_product != blank and selected_variant != blank and selected_variant.available
    assign product_available = true
  endif
%}

<section class="belle-repousse-landing" aria-label="{{ section.settings.accessibility_label | escape }}">
  <div class="belle-repousse-landing__announcement">
    <span>{{ section.settings.announcement | escape }}</span>
  </div>

  <div class="page-width belle-repousse-landing__hero">
    <div class="belle-repousse-landing__gallery" aria-label="{{ section.settings.gallery_label | escape }}">
      <figure class="belle-repousse-landing__main-media">
        <img
          src="{{ section.settings.hero_image_url | escape }}"
          alt="{{ section.settings.hero_image_alt | escape }}"
          width="1531"
          height="1027"
          loading="eager"
        >
      </figure>

      <div class="belle-repousse-landing__thumbnails">
        {% if section.settings.detail_image_1_url != blank %}
          <img
            src="{{ section.settings.detail_image_1_url | escape }}"
            alt="{{ section.settings.detail_image_1_alt | escape }}"
            width="800"
            height="800"
            loading="lazy"
          >
        {% endif %}
        {% if section.settings.detail_image_2_url != blank %}
          <img
            src="{{ section.settings.detail_image_2_url | escape }}"
            alt="{{ section.settings.detail_image_2_alt | escape }}"
            width="800"
            height="800"
            loading="lazy"
          >
        {% endif %}
        {% if section.settings.detail_image_3_url != blank %}
          <img
            src="{{ section.settings.detail_image_3_url | escape }}"
            alt="{{ section.settings.detail_image_3_alt | escape }}"
            width="800"
            height="800"
            loading="lazy"
          >
        {% endif %}
      </div>
    </div>

    <div class="belle-repousse-landing__panel">
      {% if section.settings.eyebrow != blank %}
        <p class="belle-repousse-landing__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      <h1 class="belle-repousse-landing__title">{{ section.settings.heading | escape }}</h1>

      {% if section.settings.lead != blank %}
        <div class="belle-repousse-landing__lead">
          {{ section.settings.lead }}
        </div>
      {% endif %}

      <div class="belle-repousse-landing__price-row" aria-label="{{ section.settings.price_label | escape }}">
        {% if featured_product != blank %}
          {% render 'price', product_resource: featured_product, show_sale_price_first: true %}
        {% else %}
          <span>{{ section.settings.fallback_price | escape }}</span>
        {% endif %}
        <span class="belle-repousse-landing__offer">{{ section.settings.offer_label | escape }}</span>
      </div>

      <div class="belle-repousse-landing__cta">
        {% if featured_product != blank and selected_variant != blank %}
          {% form 'product', featured_product, class: 'belle-repousse-landing__form' %}
            <input
              type="hidden"
              name="id"
              value="{{ selected_variant.id }}"
            >
            <input
              type="hidden"
              name="quantity"
              value="1"
            >
            <button
              class="belle-repousse-landing__button"
              type="submit"
              name="add"
              {% unless product_available %}disabled{% endunless %}
            >
              {% if product_available %}
                {{ section.settings.primary_button_label | escape }}
              {% else %}
                {{ section.settings.sold_out_label | escape }}
              {% endif %}
            </button>
          {% endform %}
        {% elsif section.settings.product_link != blank %}
          <a class="belle-repousse-landing__button" href="{{ section.settings.product_link }}">
            {{ section.settings.primary_button_label | escape }}
          </a>
        {% endif %}

        <a class="belle-repousse-landing__button belle-repousse-landing__button--secondary" href="#details-belle-repousse">
          {{ section.settings.secondary_button_label | escape }}
        </a>
      </div>

      <ul class="belle-repousse-landing__trust" aria-label="{{ section.settings.trust_label | escape }}">
        <li>{{ section.settings.trust_item_1 | escape }}</li>
        <li>{{ section.settings.trust_item_2 | escape }}</li>
        <li>{{ section.settings.trust_item_3 | escape }}</li>
      </ul>
    </div>
  </div>

  <div class="page-width belle-repousse-landing__benefits" id="details-belle-repousse">
    <article class="belle-repousse-landing__benefit">
      <span>{{ section.settings.benefit_1_number | escape }}</span>
      <h2>{{ section.settings.benefit_1_title | escape }}</h2>
      <p>{{ section.settings.benefit_1_copy | escape }}</p>
    </article>
    <article class="belle-repousse-landing__benefit">
      <span>{{ section.settings.benefit_2_number | escape }}</span>
      <h2>{{ section.settings.benefit_2_title | escape }}</h2>
      <p>{{ section.settings.benefit_2_copy | escape }}</p>
    </article>
    <article class="belle-repousse-landing__benefit">
      <span>{{ section.settings.benefit_3_number | escape }}</span>
      <h2>{{ section.settings.benefit_3_title | escape }}</h2>
      <p>{{ section.settings.benefit_3_copy | escape }}</p>
    </article>
  </div>

  <div class="page-width belle-repousse-landing__routine">
    <div>
      <p class="belle-repousse-landing__eyebrow">{{ section.settings.routine_eyebrow | escape }}</p>
      <h2>{{ section.settings.routine_heading | escape }}</h2>
    </div>

    <ol class="belle-repousse-landing__steps">
      <li>{{ section.settings.step_1 | escape }}</li>
      <li>{{ section.settings.step_2 | escape }}</li>
      <li>{{ section.settings.step_3 | escape }}</li>
    </ol>
  </div>

  <div class="page-width belle-repousse-landing__details">
    <div class="belle-repousse-landing__specs">
      <h2>{{ section.settings.specs_heading | escape }}</h2>
      <dl>
        <div>
          <dt>{{ section.settings.spec_1_label | escape }}</dt>
          <dd>{{ section.settings.spec_1_value | escape }}</dd>
        </div>
        <div>
          <dt>{{ section.settings.spec_2_label | escape }}</dt>
          <dd>{{ section.settings.spec_2_value | escape }}</dd>
        </div>
        <div>
          <dt>{{ section.settings.spec_3_label | escape }}</dt>
          <dd>{{ section.settings.spec_3_value | escape }}</dd>
        </div>
        <div>
          <dt>{{ section.settings.spec_4_label | escape }}</dt>
          <dd>{{ section.settings.spec_4_value | escape }}</dd>
        </div>
      </dl>
    </div>

    <div class="belle-repousse-landing__faq">
      <p class="belle-repousse-landing__eyebrow">{{ section.settings.faq_eyebrow | escape }}</p>
      <h2>{{ section.settings.faq_heading | escape }}</h2>
      <details>
        <summary>{{ section.settings.faq_1_question | escape }}</summary>
        <p>{{ section.settings.faq_1_answer | escape }}</p>
      </details>
      <details>
        <summary>{{ section.settings.faq_2_question | escape }}</summary>
        <p>{{ section.settings.faq_2_answer | escape }}</p>
      </details>
      <details>
        <summary>{{ section.settings.faq_3_question | escape }}</summary>
        <p>{{ section.settings.faq_3_answer | escape }}</p>
      </details>
    </div>
  </div>
</section>

{% stylesheet %}
  .belle-repousse-landing {
    background: #fbf2ee;
    color: #201b18;
    overflow: hidden;
  }

  .belle-repousse-landing .page-width {
    box-sizing: border-box;
    width: min(100%, 1560px);
    padding-inline: clamp(18px, 4vw, 48px);
  }

  .belle-repousse-landing__announcement {
    display: flex;
    min-height: 38px;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: #3b1214;
    color: #ffffff;
    font-size: 0.86rem;
    font-weight: 700;
    text-align: center;
  }

  .belle-repousse-landing__hero {
    display: grid;
    gap: clamp(24px, 5vw, 60px);
    align-items: center;
    padding-block: clamp(24px, 6vw, 76px) clamp(36px, 7vw, 88px);
  }

  @media screen and (min-width: 960px) {
    .belle-repousse-landing__hero {
      grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
    }
  }

  .belle-repousse-landing__gallery {
    display: grid;
    gap: 12px;
  }

  .belle-repousse-landing__main-media {
    margin: 0;
    overflow: hidden;
    border: 1px solid #ead0c5;
    border-radius: 8px;
    background: #ffffff;
  }

  .belle-repousse-landing__main-media img,
  .belle-repousse-landing__thumbnails img {
    display: block;
    width: 100%;
    height: auto;
  }

  .belle-repousse-landing__thumbnails {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .belle-repousse-landing__thumbnails img {
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid #eaded4;
    border-radius: 8px;
    background: #ffffff;
    object-fit: cover;
  }

  .belle-repousse-landing__panel {
    display: grid;
    gap: 18px;
    align-content: center;
  }

  .belle-repousse-landing__eyebrow {
    margin: 0;
    color: #9b2028;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .belle-repousse-landing__title {
    max-width: 760px;
    margin: 0;
    font-size: clamp(2.3rem, 5.6vw, 5.4rem);
    line-height: 0.96;
  }

  .belle-repousse-landing__lead {
    max-width: 620px;
    color: #4d4540;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.65;
  }

  .belle-repousse-landing__lead p {
    margin: 0;
  }

  .belle-repousse-landing__price-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    color: #201b18;
    font-size: 1.45rem;
    font-weight: 800;
  }

  .belle-repousse-landing__offer {
    border: 1px solid #d9c7b6;
    border-radius: 999px;
    padding: 6px 10px;
    background: #ffffff;
    color: #203a32;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .belle-repousse-landing__cta {
    display: grid;
    gap: 10px;
  }

  @media screen and (min-width: 560px) {
    .belle-repousse-landing__cta {
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.74fr);
    }
  }

  .belle-repousse-landing__form {
    margin: 0;
  }

  .belle-repousse-landing__button {
    display: inline-flex;
    width: 100%;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    border: 1px solid #9b2028;
    border-radius: 6px;
    padding: 0 20px;
    background: #9b2028;
    color: #ffffff;
    font: inherit;
    font-weight: 800;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
  }

  .belle-repousse-landing__button:hover {
    background: #7f171f;
  }

  .belle-repousse-landing__button:disabled {
    border-color: #a99d93;
    background: #a99d93;
    cursor: not-allowed;
  }

  .belle-repousse-landing__button--secondary {
    border-color: #d6c8bd;
    background: #ffffff;
    color: #201b18;
  }

  .belle-repousse-landing__button--secondary:hover {
    background: #efe6dc;
  }

  .belle-repousse-landing__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .belle-repousse-landing__trust li {
    border-radius: 999px;
    padding: 8px 11px;
    background: #e7eee7;
    color: #263626;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .belle-repousse-landing__benefits,
  .belle-repousse-landing__routine,
  .belle-repousse-landing__details {
    padding-block: clamp(34px, 6vw, 70px);
  }

  .belle-repousse-landing__benefits {
    display: grid;
    gap: 14px;
    border-block: 1px solid #e2d4c8;
  }

  @media screen and (min-width: 760px) {
    .belle-repousse-landing__benefits {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .belle-repousse-landing__benefit {
    border: 1px solid #eaded4;
    border-radius: 8px;
    padding: clamp(18px, 3vw, 26px);
    background: #ffffff;
  }

  .belle-repousse-landing__benefit span {
    display: inline-flex;
    width: 34px;
    height: 34px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #3b1214;
    color: #ffffff;
    font-size: 0.84rem;
    font-weight: 800;
  }

  .belle-repousse-landing__benefit h2 {
    margin: 18px 0 8px;
    font-size: clamp(1.15rem, 2vw, 1.55rem);
  }

  .belle-repousse-landing__benefit p {
    margin: 0;
    color: #5c514a;
    line-height: 1.55;
  }

  .belle-repousse-landing__routine {
    display: grid;
    gap: 24px;
    align-items: start;
  }

  @media screen and (min-width: 900px) {
    .belle-repousse-landing__routine {
      grid-template-columns: minmax(260px, 0.7fr) minmax(0, 1fr);
    }
  }

  .belle-repousse-landing__routine h2,
  .belle-repousse-landing__specs h2 {
    margin: 8px 0 0;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    line-height: 1.05;
  }

  .belle-repousse-landing__steps {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: routine;
  }

  .belle-repousse-landing__steps li {
    counter-increment: routine;
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    border: 1px solid #e1d3c7;
    border-radius: 8px;
    padding: 15px;
    background: #ffffff;
    color: #4d4540;
  }

  .belle-repousse-landing__steps li::before {
    content: counter(routine);
    display: inline-flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #f6ded5;
    color: #7f171f;
    font-weight: 800;
  }

  .belle-repousse-landing__details {
    display: grid;
    gap: 24px;
    background: #ffffff;
  }

  @media screen and (min-width: 900px) {
    .belle-repousse-landing__details {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
    }
  }

  .belle-repousse-landing__specs dl {
    display: grid;
    gap: 0;
    margin: 24px 0 0;
    border-top: 1px solid #e5d8ce;
  }

  .belle-repousse-landing__specs dl div {
    display: grid;
    grid-template-columns: minmax(120px, 0.45fr) minmax(0, 1fr);
    gap: 14px;
    border-bottom: 1px solid #e5d8ce;
    padding: 14px 0;
  }

  .belle-repousse-landing__specs dt {
    color: #6a5d55;
    font-weight: 700;
  }

  .belle-repousse-landing__specs dd {
    margin: 0;
    color: #201b18;
    font-weight: 700;
  }

  .belle-repousse-landing__faq {
    display: grid;
    gap: 10px;
  }

  .belle-repousse-landing__faq h2 {
    margin: 0 0 8px;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    line-height: 1.05;
  }

  .belle-repousse-landing__faq details {
    border: 1px solid #e1d3c7;
    border-radius: 8px;
    padding: 16px 18px;
    background: #f8f5f0;
  }

  .belle-repousse-landing__faq summary {
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: space-between;
    color: #201b18;
    font-weight: 800;
  }

  .belle-repousse-landing__faq summary::after {
    content: '+';
    display: inline-flex;
    width: 32px;
    height: 32px;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #9b2028;
    color: #ffffff;
    font-size: 1.15rem;
    line-height: 1;
  }

  .belle-repousse-landing__faq details[open] summary::after {
    content: '-';
  }

  .belle-repousse-landing__faq p {
    margin: 12px 0 0;
    color: #5c514a;
    line-height: 1.55;
  }

  @media screen and (max-width: 559px) {
    .belle-repousse-landing__title {
      font-size: 2.45rem;
    }

    .belle-repousse-landing__thumbnails {
      gap: 8px;
    }

    .belle-repousse-landing__specs dl div {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
{% endstylesheet %}

