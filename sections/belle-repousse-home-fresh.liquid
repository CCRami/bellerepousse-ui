{% liquid
  assign featured_product = section.settings.featured_product
  if featured_product == blank
    assign featured_product = all_products['brosse-de-massage-cuir-chevelu-led-rouge-630-nm-avec-applicateur-dhuile']
  endif
  assign selected_variant = featured_product.selected_or_first_available_variant
  assign product_available = false
  if selected_variant != blank and selected_variant.available
    assign product_available = true
  endif
  assign editorial_image = featured_product.images[1]
  assign hero_image_url = 'https://cdn.shopify.com/s/files/1/0949/5311/1937/files/belle-repousse-brosse-led-rouge-produit.png?v=1783683601'
  assign hero_poster_url = hero_image_url
  if section.settings.hero_image != blank
    assign hero_poster_url = section.settings.hero_image | image_url: width: 2200
  endif
  assign red_image_1 = 'belle-repousse-rouge-1.png' | asset_url
  assign red_image_2 = 'belle-repousse-rouge-2.png' | asset_url
  assign red_image_3 = 'belle-repousse-rouge-3.png' | asset_url
  assign red_image_4 = 'belle-repousse-rouge-4.png' | asset_url
  assign black_image_1 = 'belle-repousse-noir-1.png' | asset_url
  assign black_image_2 = 'belle-repousse-noir-2.png' | asset_url
  assign black_image_3 = 'belle-repousse-noir-3.png' | asset_url
  assign black_image_4 = 'belle-repousse-noir-4.png' | asset_url
%}

{{ 'belle-repousse-home.css' | asset_url | stylesheet_tag }}
{{ 'belle-repousse-enhancements.css' | asset_url | stylesheet_tag }}
{{ 'belle-repousse-color-gallery.css' | asset_url | stylesheet_tag }}
<script src="{{ 'belle-repousse-gallery.js' | asset_url }}" defer></script>
<script src="{{ 'belle-repousse-purchase.js' | asset_url }}" defer></script>

<section class="br-home" aria-label="{{ section.settings.accessibility_label | escape }}">
  <div class="br-home__announcement">{{ section.settings.announcement | escape }}</div>

  <div class="br-home__hero-banner br-home__hero-banner--{{ section.settings.hero_height }}">
    <img class="br-home__hero-image" src="{{ hero_poster_url }}" alt="Brosse Belle Repousse de massage du cuir chevelu avec lumière rouge" width="1920" height="720" loading="eager">
    <video class="br-home__hero-video" autoplay muted loop playsinline preload="metadata" poster="{{ hero_poster_url }}" aria-hidden="true">
      {% if section.settings.hero_video != blank %}
        {% for source in section.settings.hero_video.sources %}<source src="{{ source.url }}" type="{{ source.mime_type }}" media="(min-width: 700px)">{% endfor %}
      {% else %}
        <source src="{{ 'belle-repousse-hero-desktop.mp4' | asset_url }}" type="video/mp4" media="(min-width: 700px)">
      {% endif %}
      {% if section.settings.hero_video_mobile != blank %}
        {% for source in section.settings.hero_video_mobile.sources %}<source src="{{ source.url }}" type="{{ source.mime_type }}" media="(max-width: 699px)">{% endfor %}
      {% else %}
        <source src="{{ 'belle-repousse-hero-mobile.mp4' | asset_url }}" type="video/mp4" media="(max-width: 699px)">
      {% endif %}
    </video>
    <a class="br-home__hero-cart" href="{{ routes.cart_url }}" aria-label="Panier, {{ cart.item_count }} article(s)">Panier <span>{{ cart.item_count }}</span></a>
    <div class="br-home__hero-banner-copy">
      <a class="br-home__hero-brand" href="{{ routes.root_url }}" aria-label="Belle Repousse - Accueil">
        <img src="{{ 'belle-repousse-logo-transparent.png' | asset_url }}" alt="Belle Repousse" width="1756" height="724">
      </a>
      <h2>{{ section.settings.hero_heading | escape }}</h2>
      <a class="br-button br-button--hero" href="#produit">{{ section.settings.hero_cta_label | escape }}</a>
    </div>
  </div>

  <div class="br-shell br-home__hero" id="produit">
    <div class="br-home__gallery" data-br-gallery>
      <div class="br-home__main-media">
        <img
          id="BelleRepousseHome-main"
          class="br-home__main-image"
          src="{{ red_image_1 }}"
          alt="Brosse Belle Repousse de massage du cuir chevelu"
          width="1254"
          height="1254"
          loading="eager"
        >
      </div>

      <div class="br-home__thumbs" aria-label="{{ section.settings.gallery_label | escape }}">
        <button type="button" class="br-home__thumb" data-br-color-thumb="Rouge" data-br-gallery-image="{{ red_image_1 }}" data-br-gallery-alt="Brosse Belle Repousse rouge avec ses accessoires" aria-label="Afficher la brosse rouge et ses accessoires" aria-pressed="true"><img src="{{ red_image_1 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Rouge" data-br-gallery-image="{{ red_image_2 }}" data-br-gallery-alt="Bénéfices de la brosse Belle Repousse rouge" aria-label="Afficher les bénéfices de la brosse rouge" aria-pressed="false"><img src="{{ red_image_2 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Rouge" data-br-gallery-image="{{ red_image_3 }}" data-br-gallery-alt="Soin ciblé avec la brosse Belle Repousse rouge" aria-label="Afficher le soin ciblé avec la brosse rouge" aria-pressed="false"><img src="{{ red_image_3 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Rouge" data-br-gallery-image="{{ red_image_4 }}" data-br-gallery-alt="Trois modes de massage de la brosse Belle Repousse rouge" aria-label="Afficher les modes de massage de la brosse rouge" aria-pressed="false"><img src="{{ red_image_4 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Noir" data-br-gallery-image="{{ black_image_1 }}" data-br-gallery-alt="Brosse Belle Repousse noire avec ses accessoires" aria-label="Afficher la brosse noire et ses accessoires" aria-pressed="false" hidden><img src="{{ black_image_1 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Noir" data-br-gallery-image="{{ black_image_2 }}" data-br-gallery-alt="Bénéfices de la brosse Belle Repousse noire" aria-label="Afficher les bénéfices de la brosse noire" aria-pressed="false" hidden><img src="{{ black_image_2 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Noir" data-br-gallery-image="{{ black_image_3 }}" data-br-gallery-alt="Soin ciblé avec la brosse Belle Repousse noire" aria-label="Afficher le soin ciblé avec la brosse noire" aria-pressed="false" hidden><img src="{{ black_image_3 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Noir" data-br-gallery-image="{{ black_image_4 }}" data-br-gallery-alt="Trois modes de massage de la brosse Belle Repousse noire" aria-label="Afficher les modes de massage de la brosse noire" aria-pressed="false" hidden><img src="{{ black_image_4 }}" alt="" width="420" height="420" loading="lazy"></button>
      </div>
    </div>

    <div class="br-home__purchase">
      <p class="br-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h1>{{ section.settings.heading | escape }}</h1>
      <div class="br-home__lead">{{ section.settings.lead }}</div>

      <div class="br-home__price" aria-label="{{ section.settings.price_label | escape }}">
        {% if selected_variant.compare_at_price > selected_variant.price %}
          <span class="br-home__price-current">{{ selected_variant.price | money }}</span>
          <s>{{ selected_variant.compare_at_price | money }}</s>
        {% else %}
          <span class="br-home__price-current">{{ selected_variant.price | money }}</span>
        {% endif %}
      </div>
      {% render 'belle-repousse-judgeme', product: featured_product, mode: 'badge' %}

      {% if featured_product != blank and selected_variant != blank %}
        {% render 'belle-repousse-purchase-options', product: featured_product, form_class: 'br-home__form', button_label: section.settings.primary_button_label, sold_out_label: section.settings.sold_out_label %}
      {% endif %}

      {% render 'belle-repousse-trust-badges', label: section.settings.trust_label, best_price_label: section.settings.trust_1, returns_label: section.settings.trust_2, payment_label: section.settings.trust_3 %}
    </div>
  </div>

  <div class="br-shell br-home__benefits" id="bienfaits">
    <div class="br-section-intro">
      <p class="br-eyebrow">{{ section.settings.benefits_eyebrow | escape }}</p>
      <h2>{{ section.settings.benefits_heading | escape }}</h2>
    </div>
    <div class="br-card-grid">
      <article class="br-card"><span>01</span><h3>{{ section.settings.benefit_1_title | escape }}</h3><p>{{ section.settings.benefit_1_copy | escape }}</p></article>
      <article class="br-card"><span>02</span><h3>{{ section.settings.benefit_2_title | escape }}</h3><p>{{ section.settings.benefit_2_copy | escape }}</p></article>
      <article class="br-card"><span>03</span><h3>{{ section.settings.benefit_3_title | escape }}</h3><p>{{ section.settings.benefit_3_copy | escape }}</p></article>
    </div>
  </div>

  <div class="br-shell br-home__editorial">
    <div class="br-home__editorial-copy">
      <p class="br-eyebrow">{{ section.settings.editorial_eyebrow | escape }}</p>
      <h2>{{ section.settings.editorial_heading | escape }}</h2>
      {{ section.settings.editorial_copy }}
      <a class="br-button br-button--secondary" href="#utilisation">{{ section.settings.editorial_button | escape }}</a>
    </div>
    {% if editorial_image != blank %}
      <figure class="br-home__editorial-media">
        {{ editorial_image | image_url: width: 1100 | image_tag: widths: '550, 800, 1100', sizes: '(min-width: 900px) 50vw, 100vw', loading: 'lazy', alt: editorial_image.alt | default: section.settings.gallery_alt }}
      </figure>
    {% endif %}
  </div>

  <div class="br-home__dark-band" id="utilisation">
    <div class="br-shell br-home__routine">
      <div>
        <p class="br-eyebrow br-eyebrow--light">{{ section.settings.routine_eyebrow | escape }}</p>
        <h2>{{ section.settings.routine_heading | escape }}</h2>
        <p>{{ section.settings.routine_copy | escape }}</p>
      </div>
      <ol class="br-steps">
        <li><span>1</span><p>{{ section.settings.step_1 | escape }}</p></li>
        <li><span>2</span><p>{{ section.settings.step_2 | escape }}</p></li>
        <li><span>3</span><p>{{ section.settings.step_3 | escape }}</p></li>
      </ol>
    </div>
  </div>

  <div class="br-shell br-home__details">
    <div>
      <p class="br-eyebrow">{{ section.settings.specs_eyebrow | escape }}</p>
      <h2>{{ section.settings.specs_heading | escape }}</h2>
    </div>
    <dl class="br-specs">
      <div><dt>{{ section.settings.spec_1_label | escape }}</dt><dd>{{ section.settings.spec_1_value | escape }}</dd></div>
      <div><dt>{{ section.settings.spec_2_label | escape }}</dt><dd>{{ section.settings.spec_2_value | escape }}</dd></div>
      <div><dt>{{ section.settings.spec_3_label | escape }}</dt><dd>{{ section.settings.spec_3_value | escape }}</dd></div>
      <div><dt>{{ section.settings.spec_4_label | escape }}</dt><dd>{{ section.settings.spec_4_value | escape }}</dd></div>
      <div><dt>{{ section.settings.spec_5_label | escape }}</dt><dd>{{ section.settings.spec_5_value | escape }}</dd></div>
      <div><dt>{{ section.settings.spec_6_label | escape }}</dt><dd>{{ section.settings.spec_6_value | escape }}</dd></div>
    </dl>
  </div>

  <div class="br-shell br-home__reviews" id="avis-clients" aria-label="Avis clients">
    <div class="br-section-intro"><p class="br-eyebrow">Avis clients</p><h2>Elles partagent leur rituel</h2></div>
    <div class="br-home__app-blocks">
      {% render 'belle-repousse-judgeme', product: featured_product, mode: 'reviews' %}
      {% content_for 'blocks' %}
    </div>
  </div>

  <div class="br-shell br-home__faq" id="faq">
    <div class="br-section-intro">
      <p class="br-eyebrow">{{ section.settings.faq_eyebrow | escape }}</p>
      <h2>{{ section.settings.faq_heading | escape }}</h2>
    </div>
    <div class="br-faq-list">
      <details><summary>{{ section.settings.faq_1_question | escape }}<span aria-hidden="true">+</span></summary><div>{{ section.settings.faq_1_answer | escape | newline_to_br }}</div></details>
      <details><summary>{{ section.settings.faq_2_question | escape }}<span aria-hidden="true">+</span></summary><div>{{ section.settings.faq_2_answer | escape | newline_to_br }}</div></details>
      <details><summary>{{ section.settings.faq_3_question | escape }}<span aria-hidden="true">+</span></summary><div>{{ section.settings.faq_3_answer | escape | newline_to_br }}</div></details>
      <details><summary>{{ section.settings.faq_4_question | escape }}<span aria-hidden="true">+</span></summary><div>{{ section.settings.faq_4_answer | escape | newline_to_br }}</div></details>
      <details><summary>{{ section.settings.faq_5_question | escape }}<span aria-hidden="true">+</span></summary><div>{{ section.settings.faq_5_answer | escape | newline_to_br }}</div></details>
      <details><summary>{{ section.settings.faq_6_question | escape }}<span aria-hidden="true">+</span></summary><div>{{ section.settings.faq_6_answer | escape | newline_to_br }}</div></details>
      <details><summary>{{ section.settings.faq_7_question | escape }}<span aria-hidden="true">+</span></summary><div>{{ section.settings.faq_7_answer | escape | newline_to_br }}</div></details>
      <details><summary>{{ section.settings.faq_8_question | escape }}<span aria-hidden="true">+</span></summary><div>{{ section.settings.faq_8_answer | escape | newline_to_br }}</div></details>
    </div>
  </div>

  <div class="br-shell br-home__closing">
    <p class="br-eyebrow">{{ section.settings.closing_eyebrow | escape }}</p>
    <h2>{{ section.settings.closing_heading | escape }}</h2>
    <a class="br-button br-button--primary" href="#produit">{{ section.settings.closing_button | escape }}</a>
  </div>

</section>

{% schema %}
{
  "name": "Belle Repousse - accueil",
  "disabled_on": {"groups": ["header", "footer"]},
  "blocks": [{"type":"@app"}],
  "settings": [
    {"type":"product","id":"featured_product","label":"Produit mis en avant","info":"Sélectionnez le produit unique vendu sur la boutique."},
    {"type":"video","id":"hero_video","label":"Vidéo du hero","info":"Lecture automatique, muette et en boucle. L'image reste utilisée si aucune vidéo n'est sélectionnée."},
    {"type":"video","id":"hero_video_mobile","label":"Vidéo du hero sur mobile","info":"Format vertical recommandé. La version Belle Repousse incluse est utilisée si ce réglage reste vide."},
    {"type":"image_picker","id":"hero_image","label":"Image de remplacement du hero"},
    {"type":"text","id":"hero_heading","label":"Titre du hero","default":"Le rituel soin du cuir chevelu, à la maison"},
    {"type":"text","id":"hero_cta_label","label":"Bouton du hero","default":"Choisir ma brosse"},
    {"type":"select","id":"hero_height","label":"Hauteur du hero","default":"720","options":[{"value":"620","label":"Compacte - 620 px"},{"value":"720","label":"Grande - 720 px"},{"value":"820","label":"Immersive - 820 px"}]},
    {"type":"text","id":"accessibility_label","label":"Libellé accessibilité","default":"Belle Repousse - soin du cuir chevelu"},
    {"type":"text","id":"announcement","label":"Annonce","default":"Livraison suivie offerte en France"},
    {"type":"text","id":"gallery_label","label":"Libellé galerie","default":"Images du produit"},
    {"type":"text","id":"gallery_alt","label":"Texte alternatif par défaut","default":"Brosse Belle Repousse de massage du cuir chevelu avec lumière rouge"},
    {"type":"text","id":"eyebrow","label":"Surtitre","default":"Brosse LED rouge 630 nm"},
    {"type":"text","id":"heading","label":"Titre principal","default":"Le geste beauté qui prend soin de votre cuir chevelu"},
    {"type":"richtext","id":"lead","label":"Introduction","default":"<p>Massez, appliquez votre huile et installez une routine cheveux simple à la maison.</p>"},
    {"type":"text","id":"price_label","label":"Libellé du prix","default":"Prix du produit"},
    {"type":"text","id":"primary_button_label","label":"Bouton principal","default":"Ajouter au panier"},
    {"type":"text","id":"sold_out_label","label":"Rupture de stock","default":"Indisponible"},
    {"type":"text","id":"trust_label","label":"Libellé des garanties","default":"Informations d'achat"},
    {"type":"text","id":"trust_1","label":"Garantie 1","default":"Meilleur prix garanti"},
    {"type":"text","id":"trust_2","label":"Garantie 2","default":"Retours sous 30 jours"},
    {"type":"text","id":"trust_3","label":"Garantie 3","default":"Paiement 100 % sécurisé"},
    {"type":"text","id":"benefits_eyebrow","label":"Surtitre bénéfices","default":"Un soin complet"},
    {"type":"text","id":"benefits_heading","label":"Titre bénéfices","default":"Une routine pensée pour vos racines"},
    {"type":"text","id":"benefit_1_title","label":"Bénéfice 1","default":"Massage doux du cuir chevelu"},
    {"type":"text","id":"benefit_1_copy","label":"Description bénéfice 1","default":"Les 72 dents rondes en silicone accompagnent un massage confortable sans tirer les cheveux."},
    {"type":"text","id":"benefit_2_title","label":"Bénéfice 2","default":"Application précise du soin"},
    {"type":"text","id":"benefit_2_copy","label":"Description bénéfice 2","default":"Le réservoir de 6 ml et les 8 billes roulantes aident à répartir huile, sérum ou lotion près des racines."},
    {"type":"text","id":"benefit_3_title","label":"Bénéfice 3","default":"Lumière rouge 630 nm"},
    {"type":"text","id":"benefit_3_copy","label":"Description bénéfice 3","default":"Une fonction LED rouge complète votre rituel de massage et de soin du cuir chevelu."},
    {"type":"text","id":"editorial_eyebrow","label":"Surtitre éditorial","default":"Le rituel Belle Repousse"},
    {"type":"text","id":"editorial_heading","label":"Titre éditorial","default":"Quelques minutes pour retrouver le plaisir de prendre soin de soi"},
    {"type":"richtext","id":"editorial_copy","label":"Texte éditorial","default":"<p>Un appareil rechargeable, une gestuelle intuitive et le soin capillaire de votre choix. Belle Repousse accompagne les cheveux secs, bouclés, fins ou épais avec un geste régulier et agréable.</p>"},
    {"type":"text","id":"editorial_button","label":"Bouton éditorial","default":"Voir le mode d'emploi"},
    {"type":"text","id":"routine_eyebrow","label":"Surtitre routine","default":"Mode d'emploi"},
    {"type":"text","id":"routine_heading","label":"Titre routine","default":"Votre routine en trois gestes"},
    {"type":"textarea","id":"routine_copy","label":"Texte routine","default":"Utilisez la brosse sur cuir chevelu sec ou légèrement humide, selon votre rituel habituel."},
    {"type":"text","id":"step_1","label":"Étape 1","default":"Remplissez le réservoir avec une huile, un sérum ou une lotion fluide."},
    {"type":"text","id":"step_2","label":"Étape 2","default":"Allumez l'appareil et choisissez l'un des trois modes de massage."},
    {"type":"text","id":"step_3","label":"Étape 3","default":"Passez la brosse par petites zones pendant la session de 10 minutes."},
    {"type":"text","id":"specs_eyebrow","label":"Surtitre caractéristiques","default":"À connaître"},
    {"type":"text","id":"specs_heading","label":"Titre caractéristiques","default":"Les détails qui comptent"},
    {"type":"text","id":"spec_1_label","label":"Caractéristique 1","default":"Modes"},
    {"type":"text","id":"spec_1_value","label":"Valeur 1","default":"3 modes de massage"},
    {"type":"text","id":"spec_2_label","label":"Caractéristique 2","default":"Embouts"},
    {"type":"text","id":"spec_2_value","label":"Valeur 2","default":"72 dents rondes en silicone"},
    {"type":"text","id":"spec_3_label","label":"Caractéristique 3","default":"Réservoir"},
    {"type":"text","id":"spec_3_value","label":"Valeur 3","default":"6 ml, 8 billes roulantes"},
    {"type":"text","id":"spec_4_label","label":"Caractéristique 4","default":"Batterie"},
    {"type":"text","id":"spec_4_value","label":"Valeur 4","default":"Lithium 1400 mAh, recharge USB-C"},
    {"type":"text","id":"spec_5_label","label":"Caractéristique 5","default":"Autonomie d'usage"},
    {"type":"text","id":"spec_5_value","label":"Valeur 5","default":"Minuteur automatique de 10 minutes"},
    {"type":"text","id":"spec_6_label","label":"Caractéristique 6","default":"Format"},
    {"type":"text","id":"spec_6_value","label":"Valeur 6","default":"21,2 x 8,5 x 3,5 cm, 233 g"},
    {"type":"text","id":"faq_eyebrow","label":"Surtitre FAQ","default":"Questions fréquentes"},
    {"type":"text","id":"faq_heading","label":"Titre FAQ","default":"Avant de commencer votre routine"},
    {"type":"text","id":"faq_1_question","label":"Question 1","default":"Quel produit puis-je mettre dans le réservoir ?"},
    {"type":"textarea","id":"faq_1_answer","label":"Réponse 1","default":"Utilisez une huile, un sérum ou une lotion capillaire fluide. Nettoyez le réservoir après usage."},
    {"type":"text","id":"faq_2_question","label":"Question 2","default":"Combien de temps dure une session ?"},
    {"type":"textarea","id":"faq_2_answer","label":"Réponse 2","default":"Le minuteur automatique est réglé sur 10 minutes, une durée pratique pour votre routine quotidienne."},
    {"type":"text","id":"faq_3_question","label":"Question 3","default":"La brosse propose-t-elle plusieurs modes ?"},
    {"type":"textarea","id":"faq_3_answer","label":"Réponse 3","default":"Oui. Les trois modes permettent d'adapter le rythme du massage à vos préférences."},
    {"type":"text","id":"faq_4_question","label":"Question 4","default":"Comment recharger la brosse ?"},
    {"type":"textarea","id":"faq_4_answer","label":"Réponse 4","default":"La batterie lithium de 1400 mAh se recharge en USB-C. Le temps de charge est d'environ trois heures."},
    {"type":"text","id":"faq_5_question","label":"Question 5","default":"Comment entretenir le produit ?"},
    {"type":"textarea","id":"faq_5_answer","label":"Réponse 5","default":"Videz et rincez le réservoir après chaque utilisation, puis séchez la brosse avant de la ranger."},
    {"type":"text","id":"faq_6_question","label":"Question 6","default":"La brosse convient-elle à tous les types de cheveux ?"},
    {"type":"textarea","id":"faq_6_answer","label":"Réponse 6","default":"Elle peut accompagner différents types de cheveux. Ajustez la pression et le rythme à votre confort."},
    {"type":"text","id":"faq_7_question","label":"Question 7","default":"La lumière rouge remplace-t-elle un avis médical ?"},
    {"type":"textarea","id":"faq_7_answer","label":"Réponse 7","default":"Non. Il s'agit d'un accessoire de bien-être et de soin capillaire, qui ne remplace ni diagnostic ni traitement médical."},
    {"type":"text","id":"faq_8_question","label":"Question 8","default":"Quels sont les délais et conditions de retour ?"},
    {"type":"textarea","id":"faq_8_answer","label":"Réponse 8","default":"La livraison suivie est offerte en France sous 7 à 12 jours ouvrés. Les retours sont prévus sous 30 jours selon la politique de remboursement."},
    {"type":"text","id":"closing_eyebrow","label":"Surtitre final","default":"Prenez soin de votre cuir chevelu"},
    {"type":"text","id":"closing_heading","label":"Titre final","default":"Votre rituel cheveux commence ici"},
    {"type":"text","id":"closing_button","label":"Bouton final","default":"Découvrir la brosse"}
  ],
  "presets": [{"name":"Belle Repousse - accueil"}]
}
{% endschema %}
