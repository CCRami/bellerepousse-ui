{% liquid
  assign red_image_1 = 'belle-repousse-rouge-1.png' | asset_url
  assign red_image_2 = 'belle-repousse-rouge-2.png' | asset_url
  assign red_image_3 = 'belle-repousse-rouge-3.png' | asset_url
  assign red_image_4 = 'belle-repousse-rouge-4.png' | asset_url
  assign black_image_1 = 'belle-repousse-noir-1.png' | asset_url
  assign black_image_2 = 'belle-repousse-noir-2.png' | asset_url
  assign black_image_3 = 'belle-repousse-noir-3.png' | asset_url
  assign black_image_4 = 'belle-repousse-noir-4.png' | asset_url
%}
{% render 'belle-repousse-site-chrome' %}
{{ 'belle-repousse-home.css' | asset_url | stylesheet_tag }}
{{ 'belle-repousse-product.css' | asset_url | stylesheet_tag }}
{{ 'belle-repousse-enhancements.css' | asset_url | stylesheet_tag }}
{{ 'belle-repousse-color-gallery.css' | asset_url | stylesheet_tag }}
<script src="{{ 'belle-repousse-gallery.js' | asset_url }}" defer></script>
<script src="{{ 'belle-repousse-purchase.js' | asset_url }}" defer></script>

<section class="br-home br-product" aria-label="{{ section.settings.accessibility_label | escape }}">
  <div class="br-home__announcement">{{ section.settings.announcement | escape }}</div>
  <div class="br-shell br-home__hero" id="produit">
    <div class="br-home__gallery" data-br-gallery>
      <div class="br-home__main-media"><img class="br-home__main-image" src="{{ red_image_1 }}" alt="Brosse Belle Repousse rouge avec ses accessoires" width="1254" height="1254" loading="eager"></div>
      <div class="br-home__thumbs" aria-label="{{ section.settings.gallery_label | escape }}">
        <button type="button" class="br-home__thumb" data-br-color-thumb="Rouge" data-br-gallery-image="{{ red_image_1 }}" data-br-gallery-alt="Brosse Belle Repousse rouge avec ses accessoires" aria-label="Afficher la brosse rouge et ses accessoires" aria-pressed="true"><img src="{{ red_image_1 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Rouge" data-br-gallery-image="{{ red_image_2 }}" data-br-gallery-alt="Bénéfices de la brosse Belle Repousse rouge" aria-label="Afficher les bénéfices de la brosse rouge" aria-pressed="false"><img src="{{ red_image_2 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Rouge" data-br-gallery-image="{{ red_image_3 }}" data-br-gallery-alt="Soin ciblé avec la brosse Belle Repousse rouge" aria-label="Afficher le soin ciblé avec la brosse rouge" aria-pressed="false"><img src="{{ red_image_3 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Rouge" data-br-gallery-image="{{ red_image_4 }}" data-br-gallery-alt="Trois modes de massage de la brosse Belle Repousse rouge" aria-label="Afficher les modes de massage de la brosse rouge" aria-pressed="false"><img src="{{ red_image_4 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Noir" data-br-gallery-image="{{ black_image_1 }}" data-br-gallery-alt="Brosse Belle Repousse noire avec ses accessoires" aria-label="Afficher la brosse noire et ses accessoires" aria-pressed="false" hidden><img src="{{ black_image_1 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Noir" data-br-gallery-image="{{ black_image_2 }}" data-br-gallery-alt="Bénéfices de la brosse Belle Repousse noire" aria-label="Afficher les bénéfices de la brosse noire" aria-pressed="false" hidden><img src="{{ black_image_2 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Noir" data-br-gallery-image="{{ black_image_3 }}" data-br-gallery-alt="Soin ciblé avec la brosse Belle Repousse noire" aria-label="Afficher le soin ciblé avec la brosse noire" aria-pressed="false" hidden><img src="{{ black_image_3 }}" alt="" width="420" height="420" loading="lazy"></button>
        <button type="button" class="br-home__thumb" data-br-color-thumb="Noir" data-br-gallery-image="{{ black_image_4 }}" data-br-gallery-alt="Trois modes de massage de la brosse Belle Repousse noire" aria-label="Afficher les modes de massage de la brosse noire" aria-pressed="false" hidden><img src="{{ black_image_4 }}" alt="" width="420" height="420" loading="lazy"></button>
      </div>
    </div>
    <div class="br-home__purchase">
      <p class="br-eyebrow">{{ section.settings.eyebrow | escape }}</p><h1>{{ product.title | escape }}</h1>
      <div class="br-home__price" aria-label="{{ section.settings.price_label | escape }}"><span class="br-home__price-current">{{ product.selected_or_first_available_variant.price | money }}</span>{% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}<s>{{ product.selected_or_first_available_variant.compare_at_price | money }}</s>{% endif %}</div>
      <div class="br-product__rating">{% render 'belle-repousse-judgeme', product: product, mode: 'badge' %}</div>
      <div class="br-home__lead"><p>{{ section.settings.lead | escape }}</p></div>
      {% render 'belle-repousse-purchase-options', product: product, form_class: 'br-home__form', button_label: section.settings.button_label, sold_out_label: section.settings.sold_out_label %}
      {% render 'belle-repousse-trust-badges', label: section.settings.trust_label, best_price_label: section.settings.trust_1, returns_label: section.settings.trust_2, payment_label: section.settings.trust_3 %}
    </div>
  </div>
  <a class="br-sticky-purchase" href="#produit" data-br-sticky-purchase data-br-target="produit" hidden>
    <span>Votre rituel</span>
    <strong>Choisir ma brosse</strong>
  </a>
  <div class="br-shell br-product__description"><p class="br-eyebrow">{{ section.settings.description_eyebrow | escape }}</p>{{ product.description }}</div>
  <div class="br-shell br-product__reviews" id="avis-clients">
    {% render 'belle-repousse-judgeme', product: product, mode: 'reviews' %}
  </div>
</section>

{% schema %}
{"name":"Belle Repousse - produit","blocks":[{"type":"@app"}],"settings":[{"type":"text","id":"accessibility_label","label":"Libellé accessibilité","default":"Produit Belle Repousse"},{"type":"text","id":"announcement","label":"Annonce","default":"Livraison suivie offerte en France"},{"type":"text","id":"gallery_label","label":"Libellé galerie","default":"Images du produit"},{"type":"text","id":"gallery_alt","label":"Texte alternatif par défaut","default":"Brosse Belle Repousse de massage du cuir chevelu"},{"type":"text","id":"eyebrow","label":"Surtitre","default":"Soin du cuir chevelu à la maison"},{"type":"text","id":"price_label","label":"Libellé du prix","default":"Prix du produit"},{"type":"text","id":"lead","label":"Introduction","default":"Massage, lumière rouge 630 nm et applicateur d'huile capillaire dans un seul rituel."},{"type":"text","id":"button_label","label":"Bouton","default":"Ajouter au panier"},{"type":"text","id":"sold_out_label","label":"Rupture","default":"Indisponible"},{"type":"text","id":"trust_label","label":"Libellé garanties","default":"Informations d'achat"},{"type":"text","id":"trust_1","label":"Garantie 1","default":"Meilleur prix garanti"},{"type":"text","id":"trust_2","label":"Garantie 2","default":"Retours sous 30 jours"},{"type":"text","id":"trust_3","label":"Garantie 3","default":"Paiement 100 % sécurisé"},{"type":"text","id":"description_eyebrow","label":"Surtitre description","default":"Tout savoir sur la brosse"}],"presets":[{"name":"Belle Repousse - produit"}]}
{% endschema %}
